# Frontend environment variables
# Copy to .env.local for local development
# Set these in Vercel dashboard for production

# DO NOT set VITE_API_URL in production or on Vercel.
# The frontend uses relative /api/ paths proxied by Vercel → EC2 (see vercel.json).
# Setting this bakes a direct URL into the bundle and bypasses the proxy.
#
# Only set it if you are running the frontend standalone without the Vercel proxy:
#   VITE_API_URL=http://localhost:8000
# VITE_API_URL=

# Supabase project settings (from Supabase Dashboard → Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
