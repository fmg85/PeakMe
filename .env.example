# =============================================================================
# PeakMe Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# --- Supabase ---
# From: Supabase Dashboard → Settings → API

# Supabase → Settings → Database → Connection string → "Session mode" (port 5432)
# Must use the psycopg3 scheme: postgresql+psycopg://  (NOT asyncpg — backend uses psycopg[async])
DATABASE_URL=postgresql+psycopg://postgres.[project-ref]:[password]@aws-1-us-west-1.pooler.supabase.com:5432/postgres

# Your Supabase project URL (e.g. https://abcdefghijkl.supabase.co)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# From: Supabase → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- AWS S3 ---
# Create an IAM user with s3:PutObject, s3:GetObject, s3:DeleteObject, s3:ListBucket permissions
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-west-1
AWS_S3_BUCKET=peakme-ions

# --- CORS ---
# Comma-separated list of allowed origins (your Vercel URL + local dev)
ALLOWED_ORIGINS=https://peakme.vercel.app,http://localhost:5173

# --- App ---
ENVIRONMENT=production
