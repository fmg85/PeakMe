# =============================================================================
# PeakMe Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# --- Supabase ---
# From: Supabase Dashboard → Settings → API

# "Session mode" connection string (port 5432 for direct connection, 6543 for pooler)
# Use the async URL: postgresql+asyncpg://...
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Your Supabase project URL (e.g. https://abcdefghijkl.supabase.co)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# From: Supabase → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- AWS S3 ---
# Create an IAM user with s3:PutObject, s3:GetObject, s3:DeleteObject, s3:ListBucket permissions
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=peakme-ions

# --- CORS ---
# Comma-separated list of allowed origins (your Vercel URL + local dev)
ALLOWED_ORIGINS=https://peakme.vercel.app,http://localhost:5173

# --- App ---
ENVIRONMENT=production
